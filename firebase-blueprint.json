{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["parent", "guest"] }
      },
      "required": ["uid", "email"]
    },
    "Registry": {
      "title": "Registry",
      "description": "A baby gift registry",
      "type": "object",
      "properties": {
        "babyName": { "type": "string" },
        "dueDate": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "currency": { "type": "string" },
        "hemisphere": { "type": "string", "enum": ["northern", "southern"] },
        "coOwnerEmails": { "type": "array", "items": { "type": "string", "format": "email" } }
      },
      "required": ["babyName", "ownerId"]
    },
    "RegistryItem": {
      "title": "RegistryItem",
      "description": "An item in a gift registry",
      "type": "object",
      "properties": {
        "registryId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "url": { "type": "string" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "quantity": { "type": "integer" },
        "quantityClaimed": { "type": "integer" },
        "quantityReserved": { "type": "integer" },
        "claims": { "type": "array" },
        "status": { "type": "string", "enum": ["available", "claimed", "reserved"] },
        "claimedBy": { "type": "string" },
        "claimedByEmail": { "type": "string" },
        "claimedAt": { "type": "string", "format": "date-time" },
        "addedBy": { "type": "string" },
        "guestMessage": { "type": "string" },
        "thankYouSent": { "type": "boolean" },
        "isGroupGifting": { "type": "boolean" },
        "amountContributed": { "type": "number" },
        "contributions": { "type": "array" },
        "reservedUntil": { "type": "string", "format": "date-time" }
      },
      "required": ["registryId", "name", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for the registry owner",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "registryId": { "type": "string" },
        "itemId": { "type": "string" },
        "itemName": { "type": "string" },
        "type": { "type": "string", "enum": ["claim", "reserve", "contribution"] },
        "message": { "type": "string" },
        "guestName": { "type": "string" },
        "guestEmail": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "message", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/registries/{registryId}": {
      "schema": "Registry",
      "description": "Baby registries"
    },
    "/items/{itemId}": {
      "schema": "RegistryItem",
      "description": "Items within registries"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    }
  }
}
